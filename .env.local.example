# === Velion Lab — Environment Variables ===
# Преимновай този файл на .env.local и пейстни тук истинските си стойности.
# НЕ commit-вай .env.local в git! (.gitignore вече го изключва.)

# --- Supabase ---
# От Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# От Supabase Dashboard → Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Stripe ---
# От Stripe Dashboard → Developers → API keys → Publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# От Stripe Dashboard → Developers → API keys → Secret key (DA НЕ СЕ commit-ва!)
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Базов URL за success/cancel redirects от Stripe Checkout
# Локално: http://localhost:3000  · Production: https://velion-lab.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
