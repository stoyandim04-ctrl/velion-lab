# === Velion Lab — Environment Variables ===
# Преимновай този файл на .env.local и пейстни тук истинските си стойности от Supabase.
# НЕ commit-вай .env.local в git! (.gitignore вече го изключва.)

# От Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# От Supabase Dashboard → Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
